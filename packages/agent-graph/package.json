{
  "name": "@creator/agent-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@creator/agent-core": "workspace:*",
    "@creator/ai-gateway": "workspace:*",
    "@creator/data-agent": "workspace:*",
    "@creator/data-contracts": "workspace:*",
    "@creator/data-kernel-client": "workspace:*",
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "1.4.7",
    "@langchain/langgraph-checkpoint-postgres": "1.0.4"
  },
  "devDependencies": {
    "@creator/ai-modules": "workspace:*",
    "@creator/mock-data": "workspace:*",
    "@types/node": "^24.10.1",
    "vitest": "^4.1.9"
  }
}

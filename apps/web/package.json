{
  "name": "@creator/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@ai-sdk/react": "4.0.5",
    "@creator/ai-modules": "workspace:*",
    "@creator/charts": "workspace:*",
    "@creator/data-agent": "workspace:*",
    "@creator/data-contracts": "workspace:*",
    "@creator/mock-data": "workspace:*",
    "@creator/ui": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.22",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  }
}

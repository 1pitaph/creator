{
  "name": "douyin-creator-ai-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev --filter=@creator/web --filter=@creator/api",
    "dev:kernel": "pnpm --filter @creator/data-kernel dev",
    "dev:desktop": "turbo dev --filter=@creator/desktop",
    "desktop:pack": "pnpm --filter @creator/desktop run pack",
    "desktop:dist": "pnpm --filter @creator/desktop run dist",
    "desktop:publish": "pnpm --filter @creator/desktop run publish:github",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test --filter=!@creator/data-kernel",
    "test:ai-smoke": "RUN_DATA_KERNEL_SMOKE=1 pnpm --filter @creator/api test:kernel-smoke",
    "test:python": "pnpm --filter @creator/data-kernel test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
